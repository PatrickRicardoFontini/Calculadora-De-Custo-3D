DATABASE_URL="mysql://root:@localhost:3306/calculadora_custos"
PORT=3333
JWT_SECRET=""
# Origem permitida pelo CORS. Em produção, aponte pro domínio real do frontend.
# Também usada pra montar o link do email de redefinição de senha.
ALLOWED_ORIGIN=http://localhost:5173
# Chave da API do Resend (resend.com), usada pro email de redefinição de senha.
RESEND_API_KEY=""
# Remetente dos emails. onboarding@resend.dev funciona sem verificar domínio, mas só
# entrega pro email da própria conta Resend — trocar por um remetente do domínio
# verificado antes de abrir pra outros makers.
RESEND_FROM_EMAIL=onboarding@resend.dev
