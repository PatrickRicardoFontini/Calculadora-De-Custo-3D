generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                 String      @id @default(uuid())
  email              String      @unique
  senhaHash          String
  nome               String
  precoKwh           Decimal?    @db.Decimal(10, 4)
  margemPadrao       Decimal?    @db.Decimal(5, 2)
  margemExtrasPadrao Decimal?    @db.Decimal(5, 2)
  templateWhatsapp   String?     @db.Text
  resetTokenHash     String?
  resetTokenExpira   DateTime?
  criadoEm           DateTime    @default(now())

  clientes   Cliente[]
  filamentos Filamento[]
  orcamentos Orcamento[]
  vendas     Venda[]
  maquinas   Maquina[]

  @@map("usuarios")
}

model Maquina {
  id             String      @id @default(uuid())
  usuarioId      String
  usuario        Usuario     @relation(fields: [usuarioId], references: [id])
  nome           String
  potenciaWatts  Decimal     @db.Decimal(10, 2)
  precoCompra    Decimal     @db.Decimal(10, 2)
  vidaUtilHoras  Decimal     @db.Decimal(10, 2)
  criadoEm       DateTime    @default(now())

  orcamentos     Orcamento[]

  @@map("maquinas")
}

model Cliente {
  id         String      @id @default(uuid())
  usuarioId  String
  usuario    Usuario     @relation(fields: [usuarioId], references: [id])
  nome       String
  whatsapp   String?
  criadoEm   DateTime    @default(now())

  orcamentos Orcamento[]

  @@map("clientes")
}

model Filamento {
  id             String             @id @default(uuid())
  usuarioId      String
  usuario        Usuario            @relation(fields: [usuarioId], references: [id])
  tipo           String
  cor            String
  marca          String?
  pesoTotalG     Decimal            @db.Decimal(10, 2)
  pesoAtualG     Decimal            @db.Decimal(10, 2)
  estoqueMinimoG Decimal            @db.Decimal(10, 2)
  precoPorGrama  Decimal?           @db.Decimal(10, 4)
  criadoEm       DateTime           @default(now())

  orcamentos     Orcamento[]
  movimentos     MovimentoEstoque[]
  coresExtras    OrcamentoFilamentoExtra[]

  @@map("filamentos")
}

enum StatusOrcamento {
  PENDENTE
  ACEITO
  RECUSADO
}

model Orcamento {
  id             String               @id @default(uuid())
  usuarioId      String
  usuario        Usuario              @relation(fields: [usuarioId], references: [id])
  clienteId      String
  cliente        Cliente              @relation(fields: [clienteId], references: [id])
  filamentoId    String
  filamento      Filamento            @relation(fields: [filamentoId], references: [id])
  maquinaId      String?
  maquina        Maquina?             @relation(fields: [maquinaId], references: [id], onDelete: SetNull)
  nome           String?
  pesoUsadoG     Decimal              @db.Decimal(10, 2)
  horasImpressao Decimal              @db.Decimal(10, 2)
  valorCalculado Decimal              @db.Decimal(10, 2)
  valorAtual     Decimal              @db.Decimal(10, 2)
  margemExtras   Decimal?             @db.Decimal(5, 2)
  status         StatusOrcamento      @default(PENDENTE)
  criadoEm       DateTime             @default(now())

  historico      OrcamentoHistorico[]
  extras         OrcamentoExtra[]
  coresExtras    OrcamentoFilamentoExtra[]
  venda          Venda?

  @@map("orcamentos")
}

model OrcamentoExtra {
  id          String    @id @default(uuid())
  orcamentoId String
  orcamento   Orcamento @relation(fields: [orcamentoId], references: [id])
  descricao   String
  valorCusto  Decimal   @db.Decimal(10, 2)

  @@map("orcamento_extras")
}

// Cor/material adicional usado no mesmo orçamento, além do filamento principal
// (Orcamento.filamentoId). A existência de pelo menos um registro aqui é o que
// define um orçamento como multi-cor — não há campo separado pra isso.
model OrcamentoFilamentoExtra {
  id          String    @id @default(uuid())
  orcamentoId String
  orcamento   Orcamento @relation(fields: [orcamentoId], references: [id])
  filamentoId String
  filamento   Filamento @relation(fields: [filamentoId], references: [id])
  pesoUsadoG  Decimal   @db.Decimal(10, 2)

  @@map("orcamento_filamento_extras")
}

model OrcamentoHistorico {
  id           String    @id @default(uuid())
  orcamentoId  String
  orcamento    Orcamento @relation(fields: [orcamentoId], references: [id])
  valor        Decimal   @db.Decimal(10, 2)
  registradoEm DateTime  @default(now())

  @@map("orcamento_historico")
}

model Venda {
  id          String             @id @default(uuid())
  usuarioId   String
  usuario     Usuario            @relation(fields: [usuarioId], references: [id])
  orcamentoId String             @unique
  orcamento   Orcamento          @relation(fields: [orcamentoId], references: [id])
  valorFinal  Decimal            @db.Decimal(10, 2)
  dataVenda   DateTime           @default(now())

  movimentos  MovimentoEstoque[]

  @@map("vendas")
}

enum TipoMovimento {
  ENTRADA
  SAIDA
}

model MovimentoEstoque {
  id          String        @id @default(uuid())
  filamentoId String
  filamento   Filamento     @relation(fields: [filamentoId], references: [id])
  vendaId     String?
  venda       Venda?        @relation(fields: [vendaId], references: [id])
  quantidadeG Decimal       @db.Decimal(10, 2)
  precoPorKg  Decimal?      @db.Decimal(10, 2)
  tipo        TipoMovimento
  data        DateTime      @default(now())

  @@map("movimento_estoque")
}
